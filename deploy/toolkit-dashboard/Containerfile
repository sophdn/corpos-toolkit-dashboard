# toolkit-dashboard container image — the React/Vite SPA, built to static
# assets and served by nginx (rootless, non-root).
#
# Build strategy: STATIC-BUILD-SERVED, not a node runtime. The dashboard is a
# Vite SPA — `vite build` emits static HTML/JS/CSS, so there's nothing to run
# at serve time. A static nginx image is smaller and has no node attack surface
# vs. keeping a node process alive. (See deploy/quadlet/README.md / the repo
# README for the rationale + the API-base-URL decision.)
#
# API base: the SPA talks to the toolkit's HTTP API cross-origin. The toolkit's
# routes are unprefixed (/chains, /bugs, …) and collide with the SPA's own
# client-side routes, so a same-origin reverse proxy can't split static-vs-API
# by path. Instead VITE_API_BASE_URL is BAKED at build time (Vite inlines env)
# via the build arg below; the toolkit's CORS is permissive so cross-origin
# fetches work. Default targets the toolkit CONTAINER's published port (:3001).
# Rebuild with --build-arg VITE_API_BASE_URL=http://<host>:3001 for LAN access.
#
# Bases pinned by DIGEST (mirrors the toolkit image). Refresh with:
#   scripts/build-image.sh --refresh-bases
#
# Build context is the REPO ROOT (package.json, src/, index.html at root).
# Build via scripts/build-image.sh.
#
#   builder : docker.io/library/node:22-bookworm
#   runtime : docker.io/nginxinc/nginx-unprivileged:1.27-alpine

# --- builder ---------------------------------------------------------------
FROM docker.io/library/node:22-bookworm@sha256:0f1cf41024e50d0592496e3bb3aef6e0f4712fe5a4b000cbd513ea76d33ab3aa AS build

# Browser-reachable base URL of the toolkit HTTP API. Baked into the bundle by
# vite (import.meta.env.VITE_API_BASE_URL). Defaults to the toolkit container's
# published port on the same host.
ARG VITE_API_BASE_URL=http://localhost:3001
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}

WORKDIR /app

# Dependency graph first so `npm ci` caches independently of source edits.
COPY package.json package-lock.json ./
RUN npm ci

# Then the source (.containerignore keeps node_modules / dist / tests-output out
# of the build context).
COPY . .

# Type-check + bundle to /app/dist. `npm run build` = tsc -b + vite build.
RUN npm run build

# --- runtime ---------------------------------------------------------------
FROM docker.io/nginxinc/nginx-unprivileged:1.27-alpine@sha256:28d91bdce70ad09025ea901458fdd149259d8e05982ade79d4ef2c0d9470eb48

LABEL org.opencontainers.image.title="toolkit-dashboard" \
      org.opencontainers.image.description="React/Vite observe dashboard for the toolkit — static SPA served by nginx, talks to the toolkit HTTP API via VITE_API_BASE_URL." \
      org.opencontainers.image.source="https://github.com/sophdn/corpos-toolkit-dashboard"

# nginx-unprivileged runs as uid 101 (nginx) and listens on 8080 — no root, no
# privileged port, which is what rootless Podman wants.
COPY deploy/toolkit-dashboard/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 8080
# CMD is inherited from the base (nginx -g 'daemon off;').
