# Frontend environment config — copy to `.env.local` and adjust.
# `.env.local` is gitignored (developer-local); this example is the
# committed template.

# Base URL of the toolkit server's HTTP observe API. The dashboard reads
# every page's data from `${VITE_API_BASE_URL}/<endpoint>` and subscribes
# to `${VITE_API_BASE_URL}/events` (SSE).
#
# Canonical host endpoint is :3001 (the containerized toolkit; the native :3000
# daemon is RETIRED post-flip — see mcp-servers/docs/TOPOLOGY.md). Host clients
# use :3001; container↔container uses the corpos-net DNS name `toolkit-server:3000`
# (NOT a host port). The source default (src/lib/http.ts) is now :3001 too.
VITE_API_BASE_URL=http://localhost:3001
